---
const images = [
  { src: '/trabajos/calefon-instalado.jpg', alt: 'Instalación de calefón Mademsa por gasfiter certificado en Santiago' },
  { src: '/trabajos/valvulas-industriales.jpg', alt: 'Instalación de válvulas industriales - gasfitería profesional' },
  { src: '/trabajos/red-sanitaria-edificio.jpg', alt: 'Red sanitaria completa en edificio - instalación sanitaria Santiago' },
  { src: '/trabajos/red-canerias-panoramica.jpg', alt: 'Red de cañerías de cobre - instalación profesional' },
  { src: '/trabajos/conexion-calefones.jpg', alt: 'Conexión de calefones a gas - servicio certificado SEC' },
  { src: '/trabajos/reparacion-lavaplatos.jpg', alt: 'Reparación de lavaplatos - gasfiter a domicilio Santiago' },
  { src: '/trabajos/reparacion-caneria.jpg', alt: 'Reparación de cañería rota - servicio de urgencia' },
  { src: '/trabajos/instalacion-wc.jpg', alt: 'Instalación de WC - gasfiter profesional Santiago' },
  { src: '/trabajos/caneria-cobre.jpg', alt: 'Trabajo en cañería de cobre - instalación sanitaria' },
  { src: '/trabajos/termo-agua.jpg', alt: 'Instalación de termo de agua caliente - gasfiter certificado' },
  { src: '/trabajos/tina-instalada.jpg', alt: 'Instalación de tina de baño - remodelación sanitaria' },
  { src: '/trabajos/obra-civil-construccion.jpg', alt: 'Obra civil y construcción - trabajos de albañilería' },
  { src: '/trabajos/remodelacion-cocina.jpg', alt: 'Remodelación de cocina - gasfitería y obras civiles' },
  { src: '/trabajos/moldaje-estructura.jpg', alt: 'Moldaje y estructura - obra civil profesional' },
  { src: '/trabajos/armadura-fierro.jpg', alt: 'Armadura de fierro - construcción y obras civiles Santiago' },
];
---

<section id="trabajos" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-primary mb-4">Trabajos Realizados</h2>
      <p class="text-lg text-text/70 max-w-2xl mx-auto">
        Algunos de mis trabajos recientes. Calidad y limpieza en cada proyecto.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
      {images.map((img, i) => (
        <a
          href={img.src}
          class="glightbox group relative overflow-hidden rounded-xl aspect-square bg-gray-100 block"
          data-gallery="trabajos"
          data-description={img.alt}
          data-aos="fade-up"
          data-aos-delay={i * 50}
        >
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <p class="absolute bottom-3 left-3 right-3 text-white font-semibold text-xs sm:text-sm">{img.alt}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />

<script is:inline src="https://cdn.jsdelivr.net/gh/mcstudios/glightbox/dist/js/glightbox.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: true,
      closeOnOutsideClick: true,
    });
  });
</script>
