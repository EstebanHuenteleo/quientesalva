---
import { siteConfig } from '../data/siteConfig';

const experience = [
  {
    period: '2019 - Presente',
    role: 'Instalador Sanitario y de Gas Independiente',
    description: 'Instalaciones sanitarias, de gas, alcantarillado. Mantención, construcción y reparación de obras menores en toda la Región Metropolitana.',
  },
  {
    period: '2017 - 2021',
    role: 'Instalador de Gas Autorizado - Metrogas',
    description: 'Instalador autorizado de sistemas de gas domiciliario. Instalación de artefactos a gas, redes de distribución y mantención conforme a normativa vigente.',
  },
  {
    period: '',
    role: 'Maestro de Mantención y Construcción - Municipalidad de San Miguel',
    description: 'Planificación y ejecución de obras menores en gas y sanitario. Apoyo técnico en infraestructura municipal.',
  },
];
---

<section id="contacto" class="py-12 sm:py-20 bg-primary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8 sm:mb-12" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Contáctame</h2>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">
        ¿Necesitas un gasfiter? Escríbeme o llámame. Respondo rápido.
      </p>
    </div>

    <!-- Desktop: 3 columns | Mobile: stacked -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10">

      <!-- Col 1: Photo + name + cert -->
      <div data-aos="fade-right" class="space-y-4">
        <a
          href="/img/salvador-huenteleo.jpg"
          class="glightbox-profile block relative overflow-hidden rounded-2xl group cursor-pointer"
          data-description={`${siteConfig.name} - Gasfiter profesional certificado SEC`}
        >
          <img
            src="/img/salvador-huenteleo.jpg"
            alt={`${siteConfig.name} - Gasfiter profesional certificado SEC en Santiago`}
            class="w-full shadow-lg group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
          <div class="absolute bottom-0 right-0 bg-accent text-white font-bold text-sm py-2 px-4 rounded-tl-xl shadow-lg">
            +10 años exp.
          </div>
        </a>

        <div class="text-center">
          <h3 class="text-xl font-bold text-white">{siteConfig.name}</h3>
          <p class="text-white/70 text-sm">{siteConfig.role}</p>
        </div>

        {siteConfig.certifications.map(cert => (
          <a
            href={cert.file}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 bg-whatsapp/20 hover:bg-whatsapp/30 text-whatsapp font-semibold text-sm px-4 py-2.5 rounded-lg transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {cert.name}
            <svg class="w-3.5 h-3.5 opacity-70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
          </a>
        ))}
      </div>

      <!-- Col 2: Experience + Education -->
      <div data-aos="fade-up" class="space-y-6">
        <!-- Experience timeline -->
        <div>
          <h4 class="text-lg font-bold text-white mb-4">Experiencia</h4>
          <div class="space-y-4">
            {experience.map(exp => (
              <div class="relative pl-5 border-l-2 border-accent/40">
                <div class="absolute -left-[5px] top-1.5 w-2 h-2 bg-accent rounded-full"></div>
                {exp.period && <span class="text-xs font-semibold text-accent">{exp.period}</span>}
                <h5 class="text-sm font-bold text-white">{exp.role}</h5>
                <p class="text-xs text-white/60">{exp.description}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Education -->
        <div>
          <h4 class="text-lg font-bold text-white mb-3">Formación</h4>
          <div class="flex items-start gap-3 bg-white/10 rounded-xl p-4">
            <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
            </svg>
            <div>
              <span class="text-xs font-semibold text-accent">2019</span>
              <h5 class="text-sm font-bold text-white">Técnico en Construcción - INACAP</h5>
              <p class="text-xs text-white/60">Carrera completa (4 semestres presenciales). En proceso de titulación.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Col 3: Form -->
      <div data-aos="fade-left">
        <form id="contact-form" class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 sm:p-8 space-y-5">
          <div>
            <label for="from_name" class="block text-white/90 text-sm font-medium mb-1.5">Nombre</label>
            <input
              type="text"
              id="from_name"
              name="from_name"
              required
              placeholder="Tu nombre"
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
            />
          </div>
          <div>
            <label for="from_email" class="block text-white/90 text-sm font-medium mb-1.5">Email</label>
            <input
              type="email"
              id="from_email"
              name="from_email"
              required
              placeholder="tu@email.com"
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
            />
          </div>
          <div>
            <label for="phone" class="block text-white/90 text-sm font-medium mb-1.5">Teléfono (opcional)</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="+56 9 XXXX XXXX"
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
            />
          </div>
          <div>
            <label for="message" class="block text-white/90 text-sm font-medium mb-1.5">Mensaje</label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              placeholder="Describe qué necesitas..."
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            id="contact-btn"
            class="w-full bg-accent hover:bg-accent/90 text-white font-bold py-3 px-6 rounded-lg transition-colors text-lg"
          >
            Enviar Mensaje
          </button>
          <div id="form-status" class="hidden text-center text-sm font-medium py-2 px-4 rounded-lg"></div>
        </form>
      </div>
    </div>

    <!-- WhatsApp + Phone: full width row -->
    <div data-aos="fade-up" class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8 lg:mt-10">
      <a
        href={`${siteConfig.whatsappLink}?text=${encodeURIComponent('Hola Salvador, necesito cotizar un servicio de gasfitería.')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 bg-whatsapp/20 hover:bg-whatsapp/30 p-5 rounded-xl transition-colors"
      >
        <div class="w-12 h-12 bg-whatsapp rounded-full flex items-center justify-center shrink-0">
          <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <div>
          <p class="text-white font-bold">WhatsApp</p>
          <p class="text-white/70 text-sm">Escríbeme directo, respondo rápido</p>
        </div>
      </a>

      <a
        href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}
        class="flex items-center gap-4 bg-white/10 hover:bg-white/15 p-5 rounded-xl transition-colors"
      >
        <div class="w-12 h-12 bg-primary-light rounded-full flex items-center justify-center shrink-0">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <div>
          <p class="text-white font-bold">{siteConfig.phone}</p>
          <p class="text-white/70 text-sm">Llámame directamente</p>
        </div>
      </a>
    </div>
  </div>
</section>

<script>
  import emailjs from '@emailjs/browser';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('contact-btn') as HTMLButtonElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = 'Enviando...';
    status.classList.add('hidden');

    try {
      await emailjs.sendForm(
        import.meta.env.PUBLIC_EMAILJS_SERVICE_ID,
        import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID,
        form,
        import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY,
      );

      status.textContent = 'Mensaje enviado correctamente. Te responderé pronto.';
      status.className = 'text-center text-sm font-medium py-2 px-4 rounded-lg bg-whatsapp/20 text-whatsapp';
      form.reset();
    } catch (err) {
      console.error('EmailJS error:', err);
      status.textContent = 'Error al enviar. Intenta por WhatsApp o teléfono.';
      status.className = 'text-center text-sm font-medium py-2 px-4 rounded-lg bg-red-500/20 text-red-300';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar Mensaje';
    }
  });
</script>
