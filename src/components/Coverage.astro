---
import { siteConfig } from '../data/siteConfig';
---

<section id="cobertura" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-primary mb-4">Zona de Cobertura</h2>
      <p class="text-lg text-text/70 max-w-2xl mx-auto mb-8">
        Atiendo en toda la Región Metropolitana. No importa la comuna, llego a donde me necesites.
      </p>

      <div class="inline-flex items-center gap-3 bg-primary/10 text-primary font-bold px-8 py-4 rounded-2xl text-xl" data-aos="fade-up" data-aos-delay="100">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
        {siteConfig.coverage}
      </div>
    </div>
  </div>
</section>
